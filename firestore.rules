rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin and not banned
    function isAdminAndNotBanned() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned != true;
    }

    // Helper function to check if the user is not banned
    function isNotBanned() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned != true;
    }

    // Helper function to check if the user owns the document
    function isOwner(userIdField) {
      return resource == null || resource.data[userIdField] == request.auth.uid;
    }

    // ────────────────────────────────────────────────────────────────
    // Public collections
    // ────────────────────────────────────────────────────────────────

    // Exercises: Public read, admin-only write (non-banned admins)
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned();
    }

    // Workout Programs: Public read, write for owner (non-banned users)
    match /workoutPrograms/{programId} {
      allow read: if true;
      allow write: if request.auth != null &&
                    isNotBanned() &&
                    isOwner('userId');
    }

    // Meal Plans: Public read, write for owner (non-banned users)
    match /mealPlans/{planId} {
      allow read: if true;
      allow write: if request.auth != null &&
                    isNotBanned() &&
                    isOwner('userId');
    }

    // Challenges: Public read, admin-only write (non-banned admins)
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned();
    }

    // Side Hustles: Public read, admin-only write (non-banned admins)
    match /sideHustles/{hustleId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned();
    }

    // Posts: Authenticated read, write only by post owner (non-banned users)
    match /posts/{postId} {
      allow read: if request.auth != null && isNotBanned();
      allow write: if request.auth != null &&
                    isNotBanned() &&
                    isOwner('userId') &&
                    request.resource.data.userId == request.auth.uid;
    }

    // Reported Posts: Admin-only read/write (non-banned admins)
    match /reported_posts/{postId} {
      allow read, write: if isAdminAndNotBanned();
    }

    // Flagged Users: Admin-only read/write (non-banned admins)
    match /flagged_users/{userId} {
      allow read, write: if isAdminAndNotBanned();
    }

    // Ingredients: Public read, admin-only write (non-banned admins)
    match /ingredients/{ingredientId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned();
    }

    // Meals: Public read, admin-only write (non-banned admins)
    match /meals/{mealId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned();
    }

    // Rewards: Public read, admin-only write (non-banned admins) with validation
    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdminAndNotBanned() &&
                    request.resource.data.points is int &&
                    request.resource.data.buttonText is string;
    }

    // ────────────────────────────────────────────────────────────────
    // Users + all subcollections
    // ────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // 1️⃣ Anyone authenticated can CREATE their own user-doc (even if it doesn't exist yet)
      allow create: if request.auth != null &&
                     request.auth.uid == uid &&
                     request.resource.data.isBanned == false &&
                     request.resource.data.isAdmin == false; // Prevent users from creating themselves as admins

      // 2️⃣ That same user can READ their doc
      allow read: if request.auth != null &&
                    request.auth.uid == uid;

      // 3️⃣ Only that same user can UPDATE or DELETE, and only if they're not banned
      //     Prevent banned users from unbanning themselves and non-admins from setting isAdmin
      allow update: if request.auth != null &&
                      request.auth.uid == uid &&
                      get(/databases/$(database)/documents/users/$(uid)).data.isBanned != true &&
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBanned']) ||
                       isAdminAndNotBanned()) &&
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']) ||
                       isAdminAndNotBanned());

      allow delete: if request.auth != null &&
                      request.auth.uid == uid &&
                      get(/databases/$(database)/documents/users/$(uid)).data.isBanned != true;

      // 4️⃣ Subcollections under /users/{uid}/...
      match /{subCollection}/{docId} {
        // General rule: Owner can read/write if not banned
        allow read, write: if request.auth != null &&
                             request.auth.uid == uid &&
                             get(/databases/$(database)/documents/users/$(uid)).data.isBanned != true;

        // Specific rule for /users/{uid}/withdrawals/{withdrawalId}: Admins can read/write
        match /withdrawals/{withdrawalId} {
          allow read, write: if (request.auth != null &&
                                request.auth.uid == uid &&
                                get(/databases/$(database)/documents/users/$(uid)).data.isBanned != true) ||
                               isAdminAndNotBanned();

          // Validate withdrawal request data
          allow write: if request.resource.data.amount is number &&
                         request.resource.data.status is string &&
                         request.resource.data.status in ['pending', 'approved', 'rejected'] &&
                         request.resource.data.payoutMethod is string &&
                         request.resource.data.payoutMethod in ['paypal', 'stripe'] &&
                         request.resource.data.recipientEmail is string;
        }
      }
    }
  }
}