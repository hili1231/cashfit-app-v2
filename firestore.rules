rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Exercises: Public read, admin-only write
    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Workout Programs: Public read, write for authenticated users (new or own programs)
    match /workoutPrograms/{programId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Meal Plans: Same as workoutPrograms
    match /mealPlans/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Challenges: Public read, admin-only write
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Side Hustles: Public read, admin-only write
    match /sideHustles/{hustleId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Posts: Authenticated read/write (assumed for community discussions)
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Ingredients: Public read, admin-only write (assumed, adjust if needed)
    match /ingredients/{ingredientId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Meals: Public read, admin-only write (assumed, adjust if needed)
    match /meals/{mealId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users: Read/write only for matching user
    match /users/{uid} {
      allow read, write: if request.auth != null;
      
      // Active Workout Programs subcollection
      match /activeWorkoutPrograms/{programId} {
        allow read, write: if request.auth != null;
      }

      // Removed Workout Programs subcollection
      match /removedWorkoutPrograms/{programId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}